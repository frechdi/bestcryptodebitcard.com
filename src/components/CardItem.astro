---
import StarRating from './StarRating.astro';
import type { CryptoCard } from '../content/cards';

interface Props {
  card: CryptoCard;
  rank?: number;
  featured?: boolean;
}

const { card, rank, featured = false } = Astro.props;
---

<article class={`card-hover bg-navy-800 border rounded-xl p-6 ${featured ? 'border-amber-500/50 ring-1 ring-amber-500/20' : 'border-navy-700'}`}>
  {rank && (
    <div class="flex items-center gap-2 mb-3">
      <span class={`inline-flex items-center justify-center w-8 h-8 rounded-full text-sm font-bold ${rank <= 3 ? 'bg-amber-500 text-navy-950' : 'bg-navy-700 text-gray-300'}`}>
        #{rank}
      </span>
      {rank === 1 && <span class="text-xs font-semibold text-amber-400 uppercase tracking-wider">Editor's Choice</span>}
    </div>
  )}

  <div class="flex flex-col sm:flex-row sm:items-start gap-4">
    <div class="flex-shrink-0 w-16 h-16 bg-navy-700 rounded-lg flex items-center justify-center">
      <svg class="w-10 h-10 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <rect x="2" y="5" width="20" height="14" rx="2" />
        <path d="M2 10h20" />
        <circle cx="17" cy="15" r="1.5" fill="currentColor" />
      </svg>
    </div>

    <div class="flex-1 min-w-0">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-2">
        <h3 class="text-xl font-bold text-white">
          <a href={`/${card.slug}`} class="hover:text-amber-400 transition-colors">{card.name}</a>
        </h3>
        <StarRating rating={card.rating} />
      </div>

      <p class="text-gray-400 text-sm mb-4 line-clamp-2">{card.description}</p>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
        <div class="bg-navy-900/50 rounded-lg p-2 text-center">
          <p class="text-xs text-gray-500">Cashback</p>
          <p class="text-sm font-semibold text-amber-400">{card.cashbackRate}</p>
        </div>
        <div class="bg-navy-900/50 rounded-lg p-2 text-center">
          <p class="text-xs text-gray-500">Annual Fee</p>
          <p class="text-sm font-semibold text-white">{card.annualFee}</p>
        </div>
        <div class="bg-navy-900/50 rounded-lg p-2 text-center">
          <p class="text-xs text-gray-500">Cryptos</p>
          <p class="text-sm font-semibold text-white">{card.supportedCryptos[card.supportedCryptos.length - 1]}</p>
        </div>
        <div class="bg-navy-900/50 rounded-lg p-2 text-center">
          <p class="text-xs text-gray-500">Regions</p>
          <p class="text-sm font-semibold text-white">{card.availableRegions.slice(0, 2).join(', ')}</p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <a href={card.affiliateUrl} target="_blank" rel="nofollow sponsored" class="cta-button inline-flex items-center justify-center px-5 py-2.5 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg text-sm">
          Visit {card.name.split(' ')[0]}
          <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
        </a>
        <a href={`/${card.slug}`} class="inline-flex items-center justify-center px-5 py-2.5 border border-navy-600 hover:border-amber-500 text-gray-300 hover:text-amber-400 font-medium rounded-lg text-sm transition-colors">
          Read Full Review
        </a>
      </div>
    </div>
  </div>
</article>
