---
interface Props {
  rating: number;
  max?: number;
}

const { rating, max = 10 } = Astro.props;
const stars = 5;
const filledStars = Math.round((rating / max) * stars * 2) / 2;

type StarType = 'full' | 'half' | 'empty';
const starTypes: StarType[] = [];
for (let i = 1; i <= stars; i++) {
  if (i <= Math.floor(filledStars)) {
    starTypes.push('full');
  } else if (i - 0.5 <= filledStars) {
    starTypes.push('half');
  } else {
    starTypes.push('empty');
  }
}
---

<div class="flex items-center gap-1" aria-label={`Rating: ${rating} out of ${max}`}>
  {starTypes.map((type, i) => (
    type === 'full' ? (
      <svg class="w-5 h-5 star-filled" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
    ) : type === 'half' ? (
      <svg class="w-5 h-5" viewBox="0 0 20 20">
        <defs>
          <linearGradient id={`half-${i}`}>
            <stop offset="50%" stop-color="#f59e0b" />
            <stop offset="50%" stop-color="#475569" />
          </linearGradient>
        </defs>
        <path fill={`url(#half-${i})`} d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ) : (
      <svg class="w-5 h-5 star-empty" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
    )
  ))}
  <span class="ml-1 text-amber-400 font-bold text-sm">{rating}/10</span>
</div>
